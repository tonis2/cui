{

  "langrev": "1",
  "warnings": [ "no-unused" ],
  "dependency-search-paths": [ "lib" ],


  "dependencies": ["vk", "c3w", "image", "font"],
  "features": [],
  "version": "0.1.0",
  "sources": [ "src/**" ],
  "test-sources": [ "test/unit/**" ],
  "output": "build",
  "script-dir": "./",
  "targets": {
    "shaders": {
      "type": "prepare",
      "exec": [
        "slangc ./src/shaders/shader.slang -force-glsl-scalar-layout -fvk-use-entrypoint-name -target spirv -emit-spirv-directly -o ./src/shaders/shader.spv"
      ]
    },
    "ui": {
      "type": "executable",
      "sources": [ "src/**", "test/main.c3" ]
    },
    "layout": {
      "type": "executable",
      "sources": [ "src/**", "test/layout.c3" ]
    },
    "composite": {
      "type": "executable",
      "sources": [ "src/**", "test/composite.c3" ]
    },
    "scroll": {
      "type": "executable",
      "sources": [ "src/**", "test/scroll.c3" ]
    },
    "text": {
      "type": "executable",
      "sources": [ "src/**", "test/text.c3" ]
    },
    "unittest": {
      "type": "executable",
      "sources": [ "src/**" ]
    }
  },
  "cpu": "generic",
  "opt": "O0"
}
