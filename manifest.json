{
  // The manifest of the released cui.c3l -- not used when building this repo, which
  // reads project.json and each dependency manifest in lib/. The c3w platform folders
  // are globbed on purpose: listing their files by hand let window.c3l add linux/xkb.c3
  // without this list following, and the artifact then failed to compile on Linux --
  // caught only by the release verify job. Keep them globs.
  "provides" : "cui",
  "sources" : [
    "src/**",
    "deps/vk/**",
    "deps/image/**",
    "deps/c3w/main.c3"
  ],
  "targets" : {
    "macos-x64" : {
      "sources" : ["deps/c3w/darwin/**"],
      "linked-libraries" : [
        "vulkan",
        "CoreFoundation.framework",
        "Cocoa.framework",
        "Metal.framework",
        "Foundation.framework",
        "AppKit.framework",
        "CoreGraphics.framework"
      ]
    },
    "macos-aarch64" : {
      "sources" : ["deps/c3w/darwin/**"],
      "linked-libraries" : [
        "vulkan",
        "CoreFoundation.framework",
        "Cocoa.framework",
        "Metal.framework",
        "Foundation.framework",
        "AppKit.framework",
        "CoreGraphics.framework"
      ]
    },
    "linux-x64" : {
      "sources" : ["deps/c3w/linux/**"],
      "linked-libraries" : ["vulkan"]
    },
    "linux-aarch64" : {
      "sources" : ["deps/c3w/linux/**"],
      "linked-libraries" : ["vulkan"]
    },
    "windows-x64" : {
      "sources" : ["deps/c3w/win32/**"],
      "linked-libraries" : ["vulkan", "user32.lib", "gdi32.lib", "kernel32.lib"]
    }
  }
}
