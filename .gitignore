# Prerequisites
*.d
/build
# Object files
*.o
*.ko
*.obj
*.elf

# Linker output
*.ilk
*.map
*.exp

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# ...except the Vulkan libraries the release artifact ships, which are committed
# on purpose (see lib/vulkanlibs.c3l/README.md). Without these exceptions the rules
# above -- *.a, *.lib, *.so, *.dylib -- would silently drop them from a commit.
!lib/vulkanlibs.c3l/**/*.a
!lib/vulkanlibs.c3l/**/*.lib
!lib/vulkanlibs.c3l/**/*.so
!lib/vulkanlibs.c3l/**/*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# Generated API docs (c3c docgen). docs/index.html IS committed — GitHub Pages
# serves it — so only the raw docgen output at the repo root is ignored.
/docs.html

# Release packaging: the .c3l artifact and the staging tree assembled into it.
# Both are built by .github/workflows/release.yml.
/cui.c3l
/pkg
