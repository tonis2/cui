{
  "provides" : "cui",
  "sources" : [
    "src/**",
    "deps/vk/**",
    "deps/image/**",
    "deps/c3w/main.c3"
  ],
  "targets" : {
    "macos-x64" : {
      "sources" : ["deps/c3w/darwin/main.c3", "deps/c3w/darwin/objc.c3"],
      "linked-libraries" : [
        "vulkan",
        "CoreFoundation.framework",
        "Cocoa.framework",
        "Metal.framework",
        "Foundation.framework",
        "AppKit.framework",
        "CoreGraphics.framework"
      ]
    },
    "macos-aarch64" : {
      "sources" : ["deps/c3w/darwin/main.c3", "deps/c3w/darwin/objc.c3"],
      "linked-libraries" : [
        "vulkan",
        "CoreFoundation.framework",
        "Cocoa.framework",
        "Metal.framework",
        "Foundation.framework",
        "AppKit.framework",
        "CoreGraphics.framework"
      ]
    },
    "linux-x64" : {
      "sources" : [
        "deps/c3w/linux/main.c3",
        "deps/c3w/linux/wayland.c3",
        "deps/c3w/linux/xdg_shell.c3",
        "deps/c3w/linux/x11.c3",
        "deps/c3w/linux/unified.c3"
      ],
      "linked-libraries" : ["vulkan"]
    },
    "linux-aarch64" : {
      "sources" : [
        "deps/c3w/linux/main.c3",
        "deps/c3w/linux/wayland.c3",
        "deps/c3w/linux/xdg_shell.c3",
        "deps/c3w/linux/x11.c3",
        "deps/c3w/linux/unified.c3"
      ],
      "linked-libraries" : ["vulkan"]
    },
    "windows-x64" : {
      "sources" : ["deps/c3w/win32/main.c3"],
      "linked-libraries" : ["vulkan", "user32.lib", "gdi32.lib", "kernel32.lib"]
    }
  }
}
