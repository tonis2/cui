{

  "langrev": "1",
  "warnings": [ "no-unused" ],
  "dependency-search-paths": [ "lib" ],
  "dependencies": ["vk", "c3w", "image"],
  "features": [],
  "version": "0.1.0",
  "sources": [ "src/**", "test/main.c3" ],
  "output": "build",
  "targets": {
    "shaders": {
      "type": "prepare",
      "exec": [
        "slangc ./src/shaders/shader.slang -force-glsl-scalar-layout -fvk-use-entrypoint-name -target spirv -emit-spirv-directly -o ./src/shaders/shader.spv"
      ]
    },
    "ui": {
      "type": "executable",
      "linked-libraries": ["vulkan"],
      "linker-search-paths": ["/usr/local/lib"],
      "link-args": ["-rpath", "/usr/local/lib"]
    }
  },
  "cpu": "generic",
  "opt": "O0"
}
