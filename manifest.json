{

  "provides" : "cui",
  "sources" : [
    "src/**",
    "deps/vk/**",
    "deps/image/**",
    "deps/font/**",
    "deps/c3w/main.c3"
  ],
  "targets" : {
    "macos-x64" : {
      "sources" : ["deps/c3w/darwin/**"],
      "linked-libraries" : [
        "CoreFoundation.framework",
        "Cocoa.framework",
        "Metal.framework",
        "Foundation.framework",
        "AppKit.framework",
        "CoreGraphics.framework"
      ]
    },
    "macos-aarch64" : {
      "sources" : ["deps/c3w/darwin/**"],
      "linked-libraries" : [
        "CoreFoundation.framework",
        "Cocoa.framework",
        "Metal.framework",
        "Foundation.framework",
        "AppKit.framework",
        "CoreGraphics.framework"
      ]
    },
    "linux-x64" : {
      "sources" : ["deps/c3w/linux/**"],
      "linked-libraries" : []
    },
    "linux-aarch64" : {
      "sources" : ["deps/c3w/linux/**"],
      "linked-libraries" : []
    },
    "windows-x64" : {
      "sources" : ["deps/c3w/win32/**"],
      "linked-libraries" : ["user32.lib", "gdi32.lib", "kernel32.lib"]
    }
  }
}
